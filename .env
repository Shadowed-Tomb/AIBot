# Telegram Bot Token (obtain from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Puter Auth Token (obtain from Puter Dashboard -> Account -> API Token)
PUTER_AUTH_TOKEN=your_puter_auth_token

# Fal.ai API Key (obtain from fal.ai dashboard)
FAL_KEY=your_fal_api_key

# Bot Owner Telegram User ID (obtain by messaging @userinfobot or similar)
OWNER_ID=your_owner_id

# Telegram API ID and API Hash (obtain from my.telegram.org)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

